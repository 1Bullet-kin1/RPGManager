<UserControl x:Class="RPGManager.Views.NpcView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:RPGManager.Views"
             xmlns:helpers="clr-namespace:RPGManager.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <UserControl.Resources>
        <helpers:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ListBox Grid.Column="0"
                 ItemsSource="{Binding NpcList}"
                 SelectedItem="{Binding SelectedNpc}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="4">
                        <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                        <TextBlock>
                            <Run Text="{Binding Race}"/>
                            <Run Text=" · "/>
                            <Run Text="{Binding Class}"/>
                        </TextBlock>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Grid Grid.Column="1">

            <TextBlock Text="Выберите NPC из списка"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Visibility="{Binding SelectedNpc,
                           Converter={StaticResource NullToVisibilityConverter},
                           ConverterParameter=inverse}"/>

            <ScrollViewer Visibility="{Binding SelectedNpc,
                              Converter={StaticResource NullToVisibilityConverter}}">
                <StackPanel Margin="16" DataContext="{Binding SelectedNpc}">

                    <TextBlock Text="{Binding Name}" FontSize="24" FontWeight="Bold"/>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="Раса: "/>
                        <TextBlock Text="{Binding Race}" FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Класс: "/>
                        <TextBlock Text="{Binding Class}" FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Уровень: "/>
                        <TextBlock Text="{Binding Level}" FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Мировоззрение: "/>
                        <TextBlock Text="{Binding Alignment}" FontWeight="Bold"/>
                    </StackPanel>

                    <Separator Margin="0,12"/>

                    <TextBlock Text="Описание" FontWeight="Bold" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap"/>

                </StackPanel>
            </ScrollViewer>

        </Grid>
    </Grid>
</UserControl>