<UserControl x:Class="RPGManager.Views.WorldView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:RPGManager.Views"
             xmlns:helpers="clr-namespace:RPGManager.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <helpers:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <DockPanel>

        <!-- Панель инструментов -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8">
            <Button Content="🌍 Добавить мир" Padding="8,4" Margin="0,0,8,0"
                    Click="AddWorld_Click"/>
            <Button Content="+ Континент" Padding="8,4" Margin="0,0,8,0"
                    Visibility="{Binding IsWorldSelected, Converter={StaticResource BoolToVis}}"
                    Click="AddContinent_Click"/>
            <Button Content="+ Регион" Padding="8,4" Margin="0,0,8,0"
                    Visibility="{Binding IsContinentSelected, Converter={StaticResource BoolToVis}}"
                    Click="AddRegion_Click"/>
            <Button Content="+ Локация" Padding="8,4" Margin="0,0,8,0"
                    Visibility="{Binding IsRegionSelected, Converter={StaticResource BoolToVis}}"
                    Click="AddLocation_Click"/>
            <Button Content="🗑 Удалить" Padding="8,4"
                    Visibility="{Binding CanDelete, Converter={StaticResource BoolToVis}}"
                    Click="Delete_Click"/>
        </StackPanel>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель — список миров с Expander-ами -->
            <ListBox Grid.Column="0"
                     ItemsSource="{Binding Worlds}"
                     SelectedItem="{Binding SelectedWorld}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Expander Margin="0,4">
                            <Expander.Header>
                                <!-- Клик на мир -->
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14"
                                           Cursor="Hand"
                                           PreviewMouseLeftButtonDown="World_Click"
                                           Tag="{Binding}"/>
                            </Expander.Header>

                            <ItemsControl ItemsSource="{Binding Continents}" Margin="12,0,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Expander Margin="0,4">
                                            <Expander.Header>
                                                <!-- Клик на континент -->
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                           Cursor="Hand"
                                                           PreviewMouseLeftButtonDown="Continent_Click"
                                                           Tag="{Binding}"/>
                                            </Expander.Header>

                                            <ItemsControl ItemsSource="{Binding Regions}" Margin="12,0,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Expander Margin="0,4">
                                                            <Expander.Header>
                                                                <!-- Клик на регион -->
                                                                <TextBlock Text="{Binding Name}"
                                                                           Cursor="Hand"
                                                                           PreviewMouseLeftButtonDown="Region_Click"
                                                                           Tag="{Binding}"/>
                                                            </Expander.Header>

                                                            <ItemsControl ItemsSource="{Binding Locations}" Margin="12,0,0,0">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <!-- Клик на локацию -->
                                                                        <TextBlock Cursor="Hand"
                                                                                   Margin="0,2"
                                                                                   PreviewMouseLeftButtonDown="Location_Click"
                                                                                   Tag="{Binding}">
                                                                            <Run Text="{Binding Name}"/>
                                                                            <Run Text=" ("/>
                                                                            <Run Text="{Binding Type}"/>
                                                                            <Run Text=")"/>
                                                                        </TextBlock>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>

                                                        </Expander>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                        </Expander>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </Expander>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Правая панель — детали + редактирование -->
            <Grid Grid.Column="1">

                <TextBlock Text="Выберите элемент из списка"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="{Binding SelectedItem,
                               Converter={StaticResource NullToVisibilityConverter},
                               ConverterParameter=inverse}"/>

                <!-- Мир -->
                <ScrollViewer Visibility="{Binding IsWorldSelected, Converter={StaticResource BoolToVis}}">
                    <StackPanel Margin="16" DataContext="{Binding SelectedItem}">
                        <TextBlock Text="Мир" FontSize="12" Opacity="0.6"/>
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="22" FontWeight="Bold"
                                 BorderThickness="0,0,0,1" Margin="0,0,0,8"/>
                        <TextBlock Text="Описание" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 MinHeight="80" Padding="4"/>
                        <Button Content="💾 Сохранить" Padding="12,6" Margin="0,12,0,0"
                                HorizontalAlignment="Left" Click="Save_Click"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Континент -->
                <ScrollViewer Visibility="{Binding IsContinentSelected, Converter={StaticResource BoolToVis}}">
                    <StackPanel Margin="16" DataContext="{Binding SelectedItem}">
                        <TextBlock Text="Континент" FontSize="12" Opacity="0.6"/>
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="22" FontWeight="Bold"
                                 BorderThickness="0,0,0,1" Margin="0,0,0,8"/>
                        <TextBlock Text="Описание" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 MinHeight="80" Padding="4"/>
                        <Button Content="💾 Сохранить" Padding="12,6" Margin="0,12,0,0"
                                HorizontalAlignment="Left" Click="Save_Click"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Регион -->
                <ScrollViewer Visibility="{Binding IsRegionSelected, Converter={StaticResource BoolToVis}}">
                    <StackPanel Margin="16" DataContext="{Binding SelectedItem}">
                        <TextBlock Text="Регион" FontSize="12" Opacity="0.6"/>
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="22" FontWeight="Bold"
                                 BorderThickness="0,0,0,1" Margin="0,0,0,8"/>
                        <TextBlock Text="Описание" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 MinHeight="80" Padding="4"/>
                        <Button Content="💾 Сохранить" Padding="12,6" Margin="0,12,0,0"
                                HorizontalAlignment="Left" Click="Save_Click"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Локация -->
                <ScrollViewer Visibility="{Binding IsLocationSelected, Converter={StaticResource BoolToVis}}">
                    <StackPanel Margin="16" DataContext="{Binding SelectedItem}">
                        <TextBlock Text="Локация" FontSize="12" Opacity="0.6"/>
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="22" FontWeight="Bold"
                                 BorderThickness="0,0,0,1" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Тип: " VerticalAlignment="Center"/>
                            <TextBox Text="{Binding Type, UpdateSourceTrigger=PropertyChanged}"
                                     Width="150" Padding="4,2"/>
                        </StackPanel>
                        <TextBlock Text="Описание" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 MinHeight="80" Padding="4"/>
                        <Button Content="💾 Сохранить" Padding="12,6" Margin="0,12,0,0"
                                HorizontalAlignment="Left" Click="Save_Click"/>
                    </StackPanel>
                </ScrollViewer>

            </Grid>
        </Grid>
    </DockPanel>
</UserControl>