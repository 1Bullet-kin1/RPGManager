<UserControl x:Class="RPGManager.Views.WorldView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:RPGManager.Views"
             xmlns:helpers="clr-namespace:RPGManager.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <helpers:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Список миров -->
        <ListBox Grid.Column="0"
                 ItemsSource="{Binding Worlds}"
                 SelectedItem="{Binding SelectedWorld}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="4">
                        <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Правая панель -->
        <Grid Grid.Column="1">

            <TextBlock Text="Выберите мир из списка"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Visibility="{Binding SelectedWorld,
                           Converter={StaticResource NullToVisibilityConverter},
                           ConverterParameter=inverse}"/>

            <ScrollViewer Visibility="{Binding SelectedWorld,
                              Converter={StaticResource NullToVisibilityConverter}}">
                <StackPanel Margin="16" DataContext="{Binding SelectedWorld}">

                    <!-- Мир -->
                    <TextBlock Text="{Binding Name}" FontSize="24" FontWeight="Bold"/>
                    <Separator Margin="0,12"/>
                    <TextBlock Text="Описание" FontWeight="Bold" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap"/>

                    <Separator Margin="0,16"/>

                    <!-- Континенты -->
                    <ItemsControl ItemsSource="{Binding Continents}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Expander Margin="0,4">
                                    <Expander.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🌍 " FontSize="14"/>
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="14" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Expander.Header>

                                    <StackPanel Margin="16,8,0,8">
                                        <TextBlock Text="{Binding Description}"
                                                   TextWrapping="Wrap" Margin="0,0,0,8"/>

                                        <!-- Регионы -->
                                        <ItemsControl ItemsSource="{Binding Regions}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Expander Margin="0,4">
                                                        <Expander.Header>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="🗺️ "/>
                                                                <TextBlock Text="{Binding Name}"
                                                                           FontWeight="SemiBold"/>
                                                            </StackPanel>
                                                        </Expander.Header>

                                                        <StackPanel Margin="16,8,0,8">
                                                            <TextBlock Text="{Binding Description}"
                                                                       TextWrapping="Wrap"
                                                                       Margin="0,0,0,8"/>

                                                            <!-- Локации -->
                                                            <ItemsControl ItemsSource="{Binding Locations}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Expander Margin="0,4">
                                                                            <Expander.Header>
                                                                                <StackPanel Orientation="Horizontal">
                                                                                    <TextBlock Text=" "/>
                                                                                    <TextBlock Text="{Binding Name}"/>
                                                                                    <TextBlock Text=" ("/>
                                                                                    <TextBlock Text="{Binding Type}"/>
                                                                                    <TextBlock Text=")"/>
                                                                                </StackPanel>
                                                                            </Expander.Header>

                                                                            <StackPanel Margin="16,8,0,8">
                                                                                <TextBlock Text="{Binding Description}"
                                                                                           TextWrapping="Wrap"
                                                                                           Margin="0,0,0,8"/>

                                                                                <!-- NPC -->
                                                                                <TextBlock Text="NPC"
                                                                                           FontWeight="Bold"
                                                                                           Margin="0,0,0,4"/>
                                                                                <ItemsControl ItemsSource="{Binding Npcs}">
                                                                                    <ItemsControl.ItemTemplate>
                                                                                        <DataTemplate>
                                                                                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                                                                                <TextBlock Text="· "/>
                                                                                                <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                                                                                <TextBlock Text=" — "/>
                                                                                                <TextBlock Text="{Binding Race}"/>
                                                                                                <TextBlock Text=", "/>
                                                                                                <TextBlock Text="{Binding Class}"/>
                                                                                            </StackPanel>
                                                                                        </DataTemplate>
                                                                                    </ItemsControl.ItemTemplate>
                                                                                </ItemsControl>

                                                                                <!-- Фракции -->
                                                                                <TextBlock Text="Фракции"
                                                                                           FontWeight="Bold"
                                                                                           Margin="0,8,0,4"/>
                                                                                <ItemsControl ItemsSource="{Binding Factions}">
                                                                                    <ItemsControl.ItemTemplate>
                                                                                        <DataTemplate>
                                                                                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                                                                                <TextBlock Text="· "/>
                                                                                                <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                                                                                <TextBlock Text=" — "/>
                                                                                                <TextBlock Text="{Binding Alignment}"/>
                                                                                            </StackPanel>
                                                                                        </DataTemplate>
                                                                                    </ItemsControl.ItemTemplate>
                                                                                </ItemsControl>

                                                                                <!-- Квесты -->
                                                                                <TextBlock Text="Квесты"
                                                                                           FontWeight="Bold"
                                                                                           Margin="0,8,0,4"/>
                                                                                <ItemsControl ItemsSource="{Binding Quests}">
                                                                                    <ItemsControl.ItemTemplate>
                                                                                        <DataTemplate>
                                                                                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                                                                                <TextBlock Text="· "/>
                                                                                                <TextBlock Text="{Binding Title}" FontWeight="Bold"/>
                                                                                                <TextBlock Text=" — "/>
                                                                                                <TextBlock Text="{Binding Status}"/>
                                                                                            </StackPanel>
                                                                                        </DataTemplate>
                                                                                    </ItemsControl.ItemTemplate>
                                                                                </ItemsControl>

                                                                            </StackPanel>
                                                                        </Expander>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>

                                                        </StackPanel>
                                                    </Expander>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                    </StackPanel>
                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>