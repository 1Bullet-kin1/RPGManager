<UserControl x:Class="RPGManager.Views.WorldView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:RPGManager.Views"
             xmlns:helpers="clr-namespace:RPGManager.Helpers"
             xmlns:models="clr-namespace:RPGManager.Models"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <helpers:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <DockPanel>

        <!-- Панель инструментов -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8">
            <Button Content="🌐 Добавить мир" Padding="8,4" Margin="0,0,8,0"
                    Click="AddWorld_Click"/>
            <Button Content="+ Континент" Padding="8,4" Margin="0,0,8,0"
                    Visibility="{Binding IsWorldSelected, Converter={StaticResource BoolToVis}}"
                    Click="AddContinent_Click"/>
            <Button Content="+ Регион" Padding="8,4" Margin="0,0,8,0"
                    Visibility="{Binding IsContinentSelected, Converter={StaticResource BoolToVis}}"
                    Click="AddRegion_Click"/>
            <Button Content="+ Локация" Padding="8,4" Margin="0,0,8,0"
                    Visibility="{Binding IsRegionSelected, Converter={StaticResource BoolToVis}}"
                    Click="AddLocation_Click"/>
        </StackPanel>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель -->
            <ScrollViewer Grid.Column="0">
                <ItemsControl ItemsSource="{Binding Worlds}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>

                            <!-- МИР -->
                            <StackPanel>
                                <Border x:Name="WorldBorder" Padding="8,6" Cursor="Hand"
                                        PreviewMouseLeftButtonDown="World_Click"
                                        Tag="{Binding}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🌐 " FontSize="13"/>
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="13" FontWeight="Bold"/>
                                    </StackPanel>
                                </Border>

                                <!-- Континенты -->
                                <ItemsControl ItemsSource="{Binding Continents}" Margin="12,0,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Expander>
                                                <Expander.Header>
                                                    <Border Padding="4,4" Cursor="Hand"
                                                            PreviewMouseLeftButtonDown="Continent_Click"
                                                            Tag="{Binding}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="🌍 "/>
                                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                    </Border>
                                                </Expander.Header>

                                                <!-- Регионы -->
                                                <ItemsControl ItemsSource="{Binding Regions}" Margin="12,0,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Expander>
                                                                <Expander.Header>
                                                                    <Border Padding="4,4" Cursor="Hand"
                                                                            PreviewMouseLeftButtonDown="Region_Click"
                                                                            Tag="{Binding}">
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <TextBlock Text="🗺️ "/>
                                                                            <TextBlock Text="{Binding Name}"/>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </Expander.Header>

                                                                <!-- Локации -->
                                                                <ItemsControl ItemsSource="{Binding Locations}" Margin="12,0,0,0">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Border Padding="4,3" Cursor="Hand"
                                                                                    PreviewMouseLeftButtonDown="Location_Click"
                                                                                    Tag="{Binding}">
                                                                                <StackPanel Orientation="Horizontal">
                                                                                    <TextBlock Text="📍 "/>
                                                                                    <TextBlock Text="{Binding Name}"/>
                                                                                    <TextBlock Text=" ("/>
                                                                                    <TextBlock Text="{Binding Type}"/>
                                                                                    <TextBlock Text=")"/>
                                                                                </StackPanel>
                                                                            </Border>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>

                                                            </Expander>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                            </Expander>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Правая панель -->
            <Grid Grid.Column="1">

                <TextBlock Text="Выберите элемент из списка"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding SelectedItem,
                               Converter={StaticResource NullToVisibilityConverter},
                               ConverterParameter=inverse}"/>

                <!-- КАРТОЧКА МИРА -->
                <ScrollViewer Visibility="{Binding IsWorldSelected, Converter={StaticResource BoolToVis}}">
                    <StackPanel Margin="16" DataContext="{Binding SelectedItem}">

                        <DockPanel Margin="0,0,0,8">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <Button Content="✏️" Padding="8,4" Margin="0,0,8,0"
                                        Click="StartEdit"/>
                                <Button Content="🗑️" Padding="8,4"
                                        Click="Delete_Click"/>
                            </StackPanel>
                            <TextBlock Text="🌐 Мир" Opacity="0.6" VerticalAlignment="Center"/>
                        </DockPanel>

                        <!-- Название — просмотр -->
                        <TextBlock Text="{Binding Name}" FontSize="24" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.IsEditMode,
                                                     RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                     Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Название — редактирование -->
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="24" FontWeight="Bold" BorderThickness="0,0,0,1">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.IsEditMode,
                                                     RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                     Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <Separator Margin="0,12"/>

                        <!-- Описание — просмотр -->
                        <TextBlock Text="{Binding Description}" TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.IsEditMode,
                                                     RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                     Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Описание — редактирование -->
                        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap" AcceptsReturn="True" MinHeight="80" Padding="4">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.IsEditMode,
                                                     RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                     Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <!-- Кнопки сохранить/отмена -->
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0"
                                    Visibility="{Binding DataContext.IsEditMode,
                                        RelativeSource={RelativeSource AncestorType=UserControl},
                                        Converter={StaticResource BoolToVis}}">
                            <Button Content="💾 Сохранить" Padding="12,6" Margin="0,0,8,0"
                                    Click="Save_Click"/>
                            <Button Content="✖ Отмена" Padding="12,6"
                                    Click="CancelEdit"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>

                <!-- КАРТОЧКА КОНТИНЕНТА -->
                <ScrollViewer Visibility="{Binding IsContinentSelected, Converter={StaticResource BoolToVis}}">
                    <StackPanel Margin="16" DataContext="{Binding SelectedItem}">

                        <DockPanel Margin="0,0,0,8">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <Button Content="✏️" Padding="8,4" Margin="0,0,8,0"
                                        Click="StartEdit"/>
                                <Button Content="🗑️" Padding="8,4"
                                        Click="Delete_Click"/>
                            </StackPanel>
                            <TextBlock Text="🌍 Континент" Opacity="0.6" VerticalAlignment="Center"/>
                        </DockPanel>

                        <TextBlock Text="{Binding Name}" FontSize="24" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.IsEditMode,
                                                     RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                     Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="24" FontWeight="Bold" BorderThickness="0,0,0,1">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.IsEditMode,
                                                     RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                     Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <Separator Margin="0,12"/>

                        <TextBlock Text="{Binding Description}" TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.IsEditMode,
                                                     RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                     Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap" AcceptsReturn="True" MinHeight="80" Padding="4">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.IsEditMode,
                                                     RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                     Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0"
                                    Visibility="{Binding DataContext.IsEditMode,
                                        RelativeSource={RelativeSource AncestorType=UserControl},
                                        Converter={StaticResource BoolToVis}}">
                            <Button Content="💾 Сохранить" Padding="12,6" Margin="0,0,8,0"
                                    Click="Save_Click"/>
                            <Button Content="✖ Отмена" Padding="12,6"
                                    Click="CancelEdit"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>

                <!-- КАРТОЧКА РЕГИОНА -->
                <ScrollViewer Visibility="{Binding IsRegionSelected, Converter={StaticResource BoolToVis}}">
                    <StackPanel Margin="16" DataContext="{Binding SelectedItem}">

                        <DockPanel Margin="0,0,0,8">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <Button Content="✏️" Padding="8,4" Margin="0,0,8,0"
                                        Click="StartEdit"/>
                                <Button Content="🗑️" Padding="8,4"
                                        Click="Delete_Click"/>
                            </StackPanel>
                            <TextBlock Text="🗺️ Регион" Opacity="0.6" VerticalAlignment="Center"/>
                        </DockPanel>

                        <TextBlock Text="{Binding Name}" FontSize="24" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.IsEditMode,
                                                     RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                     Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="24" FontWeight="Bold" BorderThickness="0,0,0,1">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.IsEditMode,
                                                     RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                     Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <Separator Margin="0,12"/>

                        <TextBlock Text="{Binding Description}" TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.IsEditMode,
                                                     RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                     Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap" AcceptsReturn="True" MinHeight="80" Padding="4">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.IsEditMode,
                                                     RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                     Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0"
                                    Visibility="{Binding DataContext.IsEditMode,
                                        RelativeSource={RelativeSource AncestorType=UserControl},
                                        Converter={StaticResource BoolToVis}}">
                            <Button Content="💾 Сохранить" Padding="12,6" Margin="0,0,8,0"
                                    Click="Save_Click"/>
                            <Button Content="✖ Отмена" Padding="12,6"
                                    Click="CancelEdit"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>

                <!-- КАРТОЧКА ЛОКАЦИИ -->
                <ScrollViewer Visibility="{Binding IsLocationSelected, Converter={StaticResource BoolToVis}}">
                    <StackPanel Margin="16" DataContext="{Binding SelectedItem}">

                        <DockPanel Margin="0,0,0,8">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <Button Content="✏️" Padding="8,4" Margin="0,0,8,0"
                                        Click="StartEdit"/>
                                <Button Content="🗑️" Padding="8,4"
                                        Click="Delete_Click"/>
                            </StackPanel>
                            <TextBlock Text="📍 Локация" Opacity="0.6" VerticalAlignment="Center"/>
                        </DockPanel>

                        <TextBlock Text="{Binding Name}" FontSize="24" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.IsEditMode,
                                                     RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                     Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="24" FontWeight="Bold" BorderThickness="0,0,0,1">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.IsEditMode,
                                                     RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                     Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <!-- Тип локации -->
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="Тип: " VerticalAlignment="Center" Opacity="0.6"/>
                            <TextBlock Text="{Binding Type}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.IsEditMode,
                                                         RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                         Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBox Text="{Binding Type, UpdateSourceTrigger=PropertyChanged}"
                                     Width="150" Padding="4,2">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.IsEditMode,
                                                         RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                         Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </StackPanel>

                        <Separator Margin="0,12"/>

                        <TextBlock Text="{Binding Description}" TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.IsEditMode,
                                                     RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                     Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap" AcceptsReturn="True" MinHeight="80" Padding="4">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.IsEditMode,
                                                     RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                     Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0"
                                    Visibility="{Binding DataContext.IsEditMode,
                                        RelativeSource={RelativeSource AncestorType=UserControl},
                                        Converter={StaticResource BoolToVis}}">
                            <Button Content="💾 Сохранить" Padding="12,6" Margin="0,0,8,0"
                                    Click="Save_Click"/>
                            <Button Content="✖ Отмена" Padding="12,6"
                                    Click="CancelEdit"/>
                        </StackPanel>

                        <Separator Margin="0,12"/>

                        <!-- NPC -->
                        <TextBlock Text="👤 NPC" FontWeight="Bold" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding Npcs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <TextBlock Text="· "/>
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                        <TextBlock Text=" — "/>
                                        <TextBlock Text="{Binding Race}"/>
                                        <TextBlock Text=", "/>
                                        <TextBlock Text="{Binding Class}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Separator Margin="0,12"/>

                        <!-- Фракции -->
                        <TextBlock Text="⚔️ Фракции" FontWeight="Bold" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding Factions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <TextBlock Text="· "/>
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                        <TextBlock Text=" — "/>
                                        <TextBlock Text="{Binding Alignment}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Separator Margin="0,12"/>

                        <!-- Квесты -->
                        <TextBlock Text="📜 Квесты" FontWeight="Bold" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding Quests}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <TextBlock Text="· "/>
                                        <TextBlock Text="{Binding Title}" FontWeight="Bold"/>
                                        <TextBlock Text=" — "/>
                                        <TextBlock Text="{Binding Status}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </ScrollViewer>

            </Grid>
        </Grid>
    </DockPanel>
</UserControl>