<UserControl x:Class="RPGManager.Views.NotesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:RPGManager.Views"
             xmlns:helpers="clr-namespace:RPGManager.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <helpers:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель -->
        <DockPanel Grid.Column="0">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8">
                <Button Content="+ Создать" Padding="8,4"
                        Click="AddNote_Click"/>
            </StackPanel>
            <ListBox ItemsSource="{Binding Notes}"
                     SelectedItem="{Binding SelectedNote}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="4">
                            <TextBlock Text="{Binding Title}" FontWeight="Bold"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding LinkedType}" Opacity="0.6"/>
                                <TextBlock Text=" · " Opacity="0.6"/>
                                <TextBlock Text="{Binding CreatedAt, StringFormat=dd.MM.yyyy}"
                                           Opacity="0.6"/>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- Правая панель -->
        <Grid Grid.Column="1">

            <TextBlock Text="Выберите заметку из списка"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="{Binding SelectedNote,
                           Converter={StaticResource NullToVisibilityConverter},
                           ConverterParameter=inverse}"/>

            <ScrollViewer Visibility="{Binding SelectedNote,
                              Converter={StaticResource NullToVisibilityConverter}}">
                <StackPanel Margin="16">

                    <!-- Заголовок + кнопки -->
                    <DockPanel Margin="0,0,0,8">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Content="✏️" Padding="8,4" Margin="0,0,8,0"
                                    Click="StartEditing_Click"/>
                            <Button Content="🗑️" Padding="8,4"
                                    Click="DeleteNote_Click"/>
                        </StackPanel>
                        <TextBlock Text="📝 Заметка" Opacity="0.6" VerticalAlignment="Center"/>
                    </DockPanel>

                    <!-- Название -->
                    <TextBlock Text="{Binding SelectedNote.Title}" FontSize="24" FontWeight="Bold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBox Text="{Binding SelectedNote.Title, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="24" FontWeight="Bold" BorderThickness="0,0,0,1">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <!-- Дата -->
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,4">
                        <TextBlock Text="Дата: " Opacity="0.6"/>
                        <TextBlock Text="{Binding SelectedNote.CreatedAt, StringFormat=dd.MM.yyyy HH:mm}"
                                   FontWeight="Bold"/>
                    </StackPanel>

                    <!-- Тип -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Тип: " Opacity="0.6" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding SelectedNote.LinkedType}" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <ComboBox ItemsSource="{Binding DataContext.LinkedTypes,
                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  SelectedItem="{Binding DataContext.SelectedNote.LinkedType,
                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  MinWidth="120">
                            <ComboBox.Style>
                                <Style TargetType="ComboBox">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ComboBox.Style>
                        </ComboBox>
                    </StackPanel>

                    <!-- Связанный объект -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Связан с: " Opacity="0.6" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding LinkedObjectName}" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- NPC -->
                        <ComboBox ItemsSource="{Binding DataContext.AllNpcs,
                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  DisplayMemberPath="Name" MinWidth="150"
                                  SelectionChanged="LinkedNpc_SelectionChanged">
                            <ComboBox.Style>
                                <Style TargetType="ComboBox">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.SelectedNote.LinkedType,
                                                     RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                     Value="NPC">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ComboBox.Style>
                        </ComboBox>

                        <!-- Location -->
                        <ComboBox ItemsSource="{Binding DataContext.AllLocations,
                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  DisplayMemberPath="Name" MinWidth="150"
                                  SelectionChanged="LinkedLocation_SelectionChanged">
                            <ComboBox.Style>
                                <Style TargetType="ComboBox">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.SelectedNote.LinkedType,
                                                     RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                     Value="Location">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ComboBox.Style>
                        </ComboBox>

                        <!-- Quest -->
                        <ComboBox ItemsSource="{Binding DataContext.AllQuests,
                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  DisplayMemberPath="Title" MinWidth="150"
                                  SelectionChanged="LinkedQuest_SelectionChanged">
                            <ComboBox.Style>
                                <Style TargetType="ComboBox">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.SelectedNote.LinkedType,
                                                     RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                     Value="Quest">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ComboBox.Style>
                        </ComboBox>

                        <!-- Faction -->
                        <ComboBox ItemsSource="{Binding DataContext.AllFactions,
                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  DisplayMemberPath="Name" MinWidth="150"
                                  SelectionChanged="LinkedFaction_SelectionChanged">
                            <ComboBox.Style>
                                <Style TargetType="ComboBox">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.SelectedNote.LinkedType,
                                                     RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                     Value="Faction">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ComboBox.Style>
                        </ComboBox>

                    </StackPanel>

                    <Separator Margin="0,0,0,12"/>

                    <!-- Содержимое -->
                    <TextBlock Text="Заметка" FontWeight="Bold" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding SelectedNote.Content}" TextWrapping="Wrap" MinHeight="40">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBox Text="{Binding SelectedNote.Content, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap" AcceptsReturn="True" MinHeight="120" Padding="8"
                             VerticalScrollBarVisibility="Auto">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <!-- Кнопки сохранить/отмена -->
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0"
                                Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}">
                        <Button Content="💾 Сохранить" Padding="12,6" Margin="0,0,8,0"
                                Click="Save_Click"/>
                        <Button Content="✖ Отмена" Padding="12,6"
                                Click="CancelEditing_Click"/>
                    </StackPanel>

                    <Separator Margin="0,12"/>

                    <!-- Описание связанного объекта -->
                    <TextBlock Text="Описание объекта" FontWeight="Bold" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding LinkedObjectDescription}" TextWrapping="Wrap"/>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>