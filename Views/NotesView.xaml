<UserControl x:Class="RPGManager.Views.NotesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:RPGManager.Views"
             xmlns:helpers="clr-namespace:RPGManager.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <helpers:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Column="0">

            <!-- Кнопки сверху -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8">
                <Button Content="+ Создать" Padding="8,4" Margin="0,0,8,0"
                        Click="AddNote_Click"/>
                <Button Content="🗑 Удалить" Padding="8,4"
                        Click="DeleteNote_Click"/>
            </StackPanel>
            <!-- Список заметок -->
        <ListBox Grid.Column="0"
                 ItemsSource="{Binding Notes}"
                 SelectedItem="{Binding SelectedNote}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="4">
                        <TextBlock Text="{Binding Title}" FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding LinkedType}"/>
                            <TextBlock Text=" · "/>
                            <TextBlock Text="{Binding CreatedAt, StringFormat=dd.MM.yyyy}"/>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
        <!-- Правая панель -->
        <Grid Grid.Column="1">

            <TextBlock Text="Выберите заметку из списка"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Visibility="{Binding SelectedNote,
                           Converter={StaticResource NullToVisibilityConverter},
                           ConverterParameter=inverse}"/>

            <ScrollViewer Visibility="{Binding SelectedNote,
                  Converter={StaticResource NullToVisibilityConverter}}">
    <StackPanel Margin="16">

        <!-- Заголовок -->
        <TextBlock Text="{Binding SelectedNote.Title}"
                   FontSize="22" FontWeight="Bold"
                   Cursor="Hand"
                   MouseLeftButtonDown="StartEditing_Click">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <TextBox Text="{Binding SelectedNote.Title, UpdateSourceTrigger=PropertyChanged}"
                 FontSize="22" FontWeight="Bold"
                 BorderThickness="0,0,0,1"
                 LostFocus="TextBox_LostFocus">
            <TextBox.Style>
                <Style TargetType="TextBox">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBox.Style>
        </TextBox>

        <StackPanel Orientation="Horizontal" Margin="0,8,0,4">
            <TextBlock Text="Тип: "/>
            <TextBlock Text="{Binding SelectedNote.LinkedType}" FontWeight="Bold"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Дата: "/>
            <TextBlock Text="{Binding SelectedNote.CreatedAt, StringFormat=dd.MM.yyyy HH:mm}"
                       FontWeight="Bold"/>
        </StackPanel>

        <Separator Margin="0,0,0,12"/>

        <TextBlock Text="Заметка" FontWeight="Bold" Margin="0,0,0,4"/>

        <!-- Содержимое -->
        <TextBlock Text="{Binding SelectedNote.Content}"
                   TextWrapping="Wrap"
                   Cursor="Hand"
                   MinHeight="40"
                   MouseLeftButtonDown="StartEditing_Click">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <TextBox Text="{Binding SelectedNote.Content, UpdateSourceTrigger=PropertyChanged}"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 MinHeight="120"
                 Padding="8"
                 VerticalScrollBarVisibility="Auto"
                 LostFocus="TextBox_LostFocus">
            <TextBox.Style>
                <Style TargetType="TextBox">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBox.Style>
        </TextBox>

        <Separator Margin="0,12"/>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Связан с: " FontWeight="Bold"/>
            <TextBlock Text="{Binding LinkedObjectName}" FontWeight="Bold"/>
        </StackPanel>

        <TextBlock Text="Описание объекта" FontWeight="Bold" Margin="0,0,0,4"/>
        <TextBlock Text="{Binding LinkedObjectDescription}" TextWrapping="Wrap"/>

    </StackPanel>
</ScrollViewer>

        </Grid>
    </Grid>
</UserControl>