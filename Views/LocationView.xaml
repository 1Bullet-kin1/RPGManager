<UserControl x:Class="RPGManager.Views.LocationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:RPGManager.Views"
             xmlns:helpers="clr-namespace:RPGManager.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <helpers:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель -->
        <DockPanel Grid.Column="0">
            <ListBox ItemsSource="{Binding Locations}"
                     SelectedItem="{Binding SelectedLocation}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="4">
                            <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Type}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- Правая панель -->
        <Grid Grid.Column="1">

            <TextBlock Text="Выберите локацию из списка"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="{Binding SelectedLocation,
                           Converter={StaticResource NullToVisibilityConverter},
                           ConverterParameter=inverse}"/>

            <ScrollViewer Visibility="{Binding SelectedLocation,
                              Converter={StaticResource NullToVisibilityConverter}}">
                <StackPanel Margin="16" DataContext="{Binding SelectedLocation}">

                    <!-- Заголовок + кнопки -->
                    <DockPanel Margin="0,0,0,8">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Content="✏️" Padding="8,4" Margin="0,0,8,0"
                                    Click="StartEditing_Click"/>
                            <Button Content="🗑️" Padding="8,4"
                                    Click="DeleteLocation_Click"/>
                        </StackPanel>
                        <TextBlock Text="📍 Локация" Opacity="0.6" VerticalAlignment="Center"/>
                    </DockPanel>

                    <!-- Название -->
                    <TextBlock Text="{Binding Name}" FontSize="24" FontWeight="Bold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsEditMode,
                                                 RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                 Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="24" FontWeight="Bold" BorderThickness="0,0,0,1">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsEditMode,
                                                 RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                 Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <!-- Тип -->
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="Тип: " Opacity="0.6" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Type}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.IsEditMode,
                                                     RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                     Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox Text="{Binding Type, UpdateSourceTrigger=PropertyChanged}"
                                 Width="150" Padding="4,2">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.IsEditMode,
                                                     RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                     Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </StackPanel>

                    <!-- Регион / Континент / Мир -->
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="Мир: " Opacity="0.6"/>
                        <TextBlock Text="{Binding Region.Continent.World.Name}" FontWeight="Bold"/>
                        <TextBlock Text=" › " Opacity="0.4"/>
                        <TextBlock Text="{Binding Region.Continent.Name}" FontWeight="Bold"/>
                        <TextBlock Text=" › " Opacity="0.4"/>
                        <TextBlock Text="{Binding Region.Name}" FontWeight="Bold"/>
                    </StackPanel>

                    <Separator Margin="0,12"/>

                    <!-- Описание -->
                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsEditMode,
                                                 RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                 Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap" AcceptsReturn="True" MinHeight="80" Padding="4">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsEditMode,
                                                 RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                 Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <!-- Кнопки сохранить/отмена -->
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0"
                                Visibility="{Binding DataContext.IsEditMode,
                                    RelativeSource={RelativeSource AncestorType=UserControl},
                                    Converter={StaticResource BoolToVis}}">
                        <Button Content="💾 Сохранить" Padding="12,6" Margin="0,0,8,0"
                                Click="Save_Click"/>
                        <Button Content="✖ Отмена" Padding="12,6"
                                Click="CancelEditing_Click"/>
                    </StackPanel>

                    <Separator Margin="0,12"/>

                    <!-- NPC -->
                    <TextBlock Text="👤 NPC" FontWeight="Bold" Margin="0,0,0,8"/>
                    <ItemsControl ItemsSource="{Binding Npcs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,2">
                                    <Button DockPanel.Dock="Right" Content="✖" Padding="4,2"
                                            Tag="{Binding}"
                                            Click="RemoveNpc_Click"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="· "/>
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                        <TextBlock Text=" — "/>
                                        <TextBlock Text="{Binding Race}"/>
                                        <TextBlock Text=", "/>
                                        <TextBlock Text="{Binding Class}"/>
                                    </StackPanel>
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <DockPanel Margin="0,8,0,0">
                        <Button DockPanel.Dock="Right" Content="+ Добавить" Padding="8,4"
                                Click="AddNpc_Click"/>
                        <ComboBox ItemsSource="{Binding DataContext.AllNpcs,
                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  SelectedItem="{Binding DataContext.NpcToAdd,
                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  DisplayMemberPath="Name"
                                  Margin="0,0,8,0"/>
                    </DockPanel>

                    <Separator Margin="0,12"/>

                    <!-- Фракции -->
                    <TextBlock Text="⚔️ Фракции" FontWeight="Bold" Margin="0,0,0,8"/>
                    <ItemsControl ItemsSource="{Binding Factions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,2">
                                    <Button DockPanel.Dock="Right" Content="✖" Padding="4,2"
                                            Tag="{Binding}"
                                            Click="RemoveFaction_Click"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="· "/>
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                        <TextBlock Text=" — "/>
                                        <TextBlock Text="{Binding Alignment}"/>
                                    </StackPanel>
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <DockPanel Margin="0,8,0,0">
                        <Button DockPanel.Dock="Right" Content="+ Добавить" Padding="8,4"
                                Click="AddFaction_Click"/>
                        <ComboBox ItemsSource="{Binding DataContext.AllFactions,
                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  SelectedItem="{Binding DataContext.FactionToAdd,
                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  DisplayMemberPath="Name"
                                  Margin="0,0,8,0"/>
                    </DockPanel>

                    <Separator Margin="0,12"/>

                    <!-- Квесты -->
                    <TextBlock Text="📜 Квесты" FontWeight="Bold" Margin="0,0,0,8"/>
                    <ItemsControl ItemsSource="{Binding Quests}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,2">
                                    <Button DockPanel.Dock="Right" Content="✖" Padding="4,2"
                                            Tag="{Binding}"
                                            Click="RemoveQuest_Click"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="· "/>
                                        <TextBlock Text="{Binding Title}" FontWeight="Bold"/>
                                        <TextBlock Text=" — "/>
                                        <TextBlock Text="{Binding Status}"/>
                                    </StackPanel>
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <DockPanel Margin="0,8,0,0">
                        <Button DockPanel.Dock="Right" Content="+ Добавить" Padding="8,4"
                                Click="AddQuest_Click"/>
                        <ComboBox ItemsSource="{Binding DataContext.AllQuests,
                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  SelectedItem="{Binding DataContext.QuestToAdd,
                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  DisplayMemberPath="Title"
                                  Margin="0,0,8,0"/>
                    </DockPanel>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>